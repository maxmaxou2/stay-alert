{
	"name": "stay-alert",
	"version": "0.0.0",
	"description": "A macOS-only CLI for staying alerted to long-running coding agent activity.",
	"license": "MIT",
	"type": "module",
	"os": [
		"darwin"
	],
	"bin": {
		"stay-alert": "./src/cli/index.ts"
	},
	"exports": {
		".": "./src/core/index.ts",
		"./core": "./src/core/index.ts"
	},
	"engines": {
		"bun": ">=1.1.0"
	},
	"scripts": {
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"format": "biome format --write ."
	},
	"files": [
		"src",
		"examples",
		"README.md",
		"LICENSE"
	],
	"dependencies": {},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@types/bun": "^1.3.13",
		"typescript": "^6.0.3"
	}
}
